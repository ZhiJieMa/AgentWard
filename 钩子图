  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

    install / update 命令触发
         │
         ▼
    ┌─────────────────────────────────────────────────────────────┐
    │  before_install  [modify]                                   │
    │  event: { targetType, targetName, sourcePath,               │
    │           builtinScan, request, skill?, plugin? }           │
